{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "example-sast",
          "version": "1.0.0"
        }
      },
      "results": [
        {
          "ruleId": "xss-001",
          "message": {
            "text": "Potential Cross-Site Scripting (XSS): User input from request.args is rendered in an HTML template via render_template_string."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/search.py" },
                "region": {
                  "startLine": 11,
                  "endLine": 15,
                  "snippet": { "text": "    query = request.args.get(\"q\", \"\")\n    return render_template_string(\n        '<h1>Results for: {{ query }}</h1>',\n        query=query,\n    )" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "xss-002",
          "message": {
            "text": "Potential Cross-Site Scripting (XSS): HTML content created with Markup() may bypass template autoescaping."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/search.py" },
                "region": {
                  "startLine": 20,
                  "endLine": 21,
                  "snippet": { "text": "    banner = Markup(\"<strong>Welcome to the help page</strong>\")\n    return render_template_string(\"{{ banner }}\", banner=banner)" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "xss-003",
          "message": {
            "text": "Cross-Site Scripting (XSS): User input from request.args inserted into HTML response using f-string without escaping."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/search.py" },
                "region": {
                  "startLine": 26,
                  "endLine": 28,
                  "snippet": { "text": "    user_input = request.args.get(\"msg\", \"\")\n    response = make_response(f\"<p>You said: {user_input}</p>\")\n    response.headers[\"Content-Type\"] = \"text/html\"" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "redirect-001",
          "message": {
            "text": "Potential Open Redirect: User-controlled URL from request.args passed to redirect() function."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/redirect_handler.py" },
                "region": {
                  "startLine": 16,
                  "endLine": 21,
                  "snippet": { "text": "    url = request.args.get(\"url\", \"\")\n    from urllib.parse import urlparse\n    parsed = urlparse(url)\n    if parsed.hostname not in ALLOWED_REDIRECT_HOSTS:\n        abort(400, \"Redirect target not allowed\")\n    return redirect(url)" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "redirect-002",
          "message": {
            "text": "Open Redirect: User-controlled URL from request.args passed directly to redirect() without validation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/redirect_handler.py" },
                "region": {
                  "startLine": 26,
                  "endLine": 27,
                  "snippet": { "text": "    target = request.args.get(\"target\", \"/\")\n    return redirect(target)" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "ssrf-001",
          "message": {
            "text": "Potential Server-Side Request Forgery (SSRF): URL constructed with f-string passed to requests.get()."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/proxy.py" },
                "region": {
                  "startLine": 13,
                  "endLine": 13,
                  "snippet": { "text": "    resp = requests.get(f\"{INTERNAL_API_BASE}/users/{user_id}\", timeout=5)" }
                }
              }
            }
          ]
        },
        {
          "ruleId": "ssrf-002",
          "message": {
            "text": "Server-Side Request Forgery (SSRF): User-supplied URL from request.args passed directly to requests.get() without validation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/routes/proxy.py" },
                "region": {
                  "startLine": 19,
                  "endLine": 20,
                  "snippet": { "text": "    url = request.args.get(\"url\", \"\")\n    resp = requests.get(url, timeout=10)" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
